  <diagram id="demo-user-flow" name="期末 Demo 使用流程">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="flow-title" value="&lt;b&gt;期末 Demo 建議展示流程&lt;/b&gt;&lt;br&gt;從訪客進站到會員點餐、付款、取餐、後台管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050816;strokeColor=#00FFFF;fontColor=#FFFFFF;fontSize=22;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1600" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="1. 首頁 index.php&lt;br&gt;品牌故事 / AI 推薦 / 熱門商品 / 智慧據點預覽" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#083344;strokeColor=#00FFFF;fontColor=#EAFBFF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="2. 註冊 / 登入&lt;br&gt;register.php：密碼強度、眼睛顯示&lt;br&gt;login.php：Demo 帳號快速帶入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2D38;strokeColor=#00B7C7;fontColor=#EAFBFF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="150" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="3. 點餐台 dashboard.php&lt;br&gt;輸入 / 掃描商品代碼&lt;br&gt;選配料並加入購物車" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2D38;strokeColor=#00FFFF;fontColor=#EAFBFF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="150" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="4. 拉麵實驗室 customize.php&lt;br&gt;客製麵體、湯底、辣度、配料&lt;br&gt;即時視覺預覽" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10192F;strokeColor=#7C3AED;fontColor=#F5F3FF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="150" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="5. 購物車 cart.php&lt;br&gt;調整數量、刪除商品&lt;br&gt;自動計算促銷與點數折抵" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#083344;strokeColor=#00FFFF;fontColor=#EAFBFF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1350" y="150" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f6" value="6. 結帳 checkout.php&lt;br&gt;Sandbox 刷卡付款&lt;br&gt;電子收據欄位：手機條碼 / 統編" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B2A08;strokeColor=#F59E0B;fontColor=#FFF7ED;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1350" y="350" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f7" value="7. 訂單成功 order-success.php&lt;br&gt;顯示訂單編號、取餐碼、QR 視覺化&lt;br&gt;可前往製作狀態" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B2E;strokeColor=#22C55E;fontColor=#DCFCE7;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="350" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f8" value="8. 製作狀態 kitchen-status.php&lt;br&gt;自動廚房進度、取餐櫃、倒數動畫&lt;br&gt;營造無人店取餐情境" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B2E;strokeColor=#86EFAC;fontColor=#DCFCE7;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="350" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f9" value="9. 訂單 / 評論 order-history.php&lt;br&gt;查看歷史訂單&lt;br&gt;完成後可送出評價或客服案件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10192F;strokeColor=#7C3AED;fontColor=#F5F3FF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="350" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f10" value="10. 會員中心 / 點數&lt;br&gt;member-center.php&lt;br&gt;rewards.php 兌換券&lt;br&gt;promotions.php 活動自動套用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10192F;strokeColor=#C084FC;fontColor=#F5F3FF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="350" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f11" value="營業真實感支線&lt;br&gt;locations.php：智慧據點 + 地圖&lt;br&gt;store-info.php：營業時間與設備狀態&lt;br&gt;partners.php：合作商圈" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#60A5FA;fontColor=#DBEAFE;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="560" width="470" height="115" as="geometry" />
        </mxCell>
        <mxCell id="f12" value="管理者後台支線&lt;br&gt;admin/index.php 儀表板&lt;br&gt;products / orders / payments / analytics&lt;br&gt;marketing：促銷、合作店、營業時間" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B0A3D;strokeColor=#FF00FF;fontColor=#FFE6FF;fontStyle=1;arcSize=10;" vertex="1" parent="1">
