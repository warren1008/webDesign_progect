<mxfile host="app.diagrams.net" modified="2026-06-16T17:45:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="current-site-architecture" name="目前網站架構總覽">
    <mxGraphModel dx="1600" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;無人拉麵商店 - 目前網站架構圖&lt;/b&gt;&lt;br&gt;依照現有 PHP 網站成果與後續優化功能整理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#050816;strokeColor=#00FFFF;fontColor=#FFFFFF;fontSize=22;fontStyle=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="70" as="geometry" />
        </mxCell>
        <mxCell id="actor-guest" value="訪客 / 新會員&lt;br&gt;Guest / Register" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#0B1324;strokeColor=#00FFFF;fontColor=#EAFBFF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="80" height="120" as="geometry" />
        </mxCell>
        <mxCell id="actor-member" value="登入會員&lt;br&gt;Member" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#0B1324;strokeColor=#00FFFF;fontColor=#EAFBFF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="80" height="120" as="geometry" />
        </mxCell>
        <mxCell id="actor-admin" value="管理者&lt;br&gt;Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#0B1324;strokeColor=#FF00FF;fontColor=#FFE6FF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="80" height="120" as="geometry" />
        </mxCell>

        <mxCell id="frontend-layer" value="前台瀏覽器層 Browser / Frontend" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#061826;strokeColor=#00B7C7;fontColor=#FFFFFF;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="240" y="130" width="650" height="520" as="geometry" />
        </mxCell>
        <mxCell id="shared-ui" value="&lt;b&gt;共用 UI 元件&lt;/b&gt;&lt;br&gt;includes/navbar.php&lt;br&gt;includes/footer.php&lt;br&gt;登入 / 會員 / 登出 / 購物車&lt;br&gt;手動收合上方選單" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#083344;strokeColor=#00FFFF;fontColor=#EAFBFF;arcSize=10;" vertex="1" parent="frontend-layer">
          <mxGeometry x="25" y="55" width="280" height="125" as="geometry" />
        </mxCell>
        <mxCell id="frontend-js" value="&lt;b&gt;前端互動 JS&lt;/b&gt;&lt;br&gt;assets/app.js&lt;br&gt;site-polish.js&lt;br&gt;feature-pages.js / customizer.js / kitchen.js&lt;br&gt;語言、幣別、密碼強度、FAQ、AI 推薦" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10192F;strokeColor=#7C3AED;fontColor=#F5F3FF;arcSize=10;" vertex="1" parent="frontend-layer">
          <mxGeometry x="335" y="55" width="290" height="125" as="geometry" />
        </mxCell>
        <mxCell id="public-pages" value="&lt;b&gt;公開 / 入口頁&lt;/b&gt;&lt;br&gt;index.php 首頁、品牌故事、AI 推薦&lt;br&gt;login.php / register.php&lt;br&gt;forgot-password.php / reset-password.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2D38;strokeColor=#00B7C7;fontColor=#EAFBFF;arcSize=10;" vertex="1" parent="frontend-layer">
          <mxGeometry x="25" y="215" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ordering-pages" value="&lt;b&gt;點餐與取餐流程&lt;/b&gt;&lt;br&gt;dashboard.php 掃描商品代碼&lt;br&gt;customize.php 拉麵實驗室&lt;br&gt;cart.php 購物車&lt;br&gt;checkout.php Sandbox 付款&lt;br&gt;order-success.php / kitchen-status.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F2D38;strokeColor=#00FFFF;fontColor=#EAFBFF;arcSize=10;" vertex="1" parent="frontend-layer">
          <mxGeometry x="335" y="215" width="290" height="145" as="geometry" />
        </mxCell>
        <mxCell id="member-pages" value="&lt;b&gt;會員與營運真實感頁面&lt;/b&gt;&lt;br&gt;member-center.php 點數中心&lt;br&gt;rewards.php 點數商城&lt;br&gt;promotions.php 活動中心&lt;br&gt;partners.php 合作商圈&lt;br&gt;locations.php 智慧據點 / store-info.php 設備監控&lt;br&gt;profile.php / order-history.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#10192F;strokeColor=#7C3AED;fontColor=#F5F3FF;arcSize=10;" vertex="1" parent="frontend-layer">
          <mxGeometry x="25" y="370" width="600" height="120" as="geometry" />
        </mxCell>

        <mxCell id="server-layer" value="後端 PHP / Apache 層" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#140B24;strokeColor=#FF00FF;fontColor=#FFFFFF;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="130" width="420" height="520" as="geometry" />
        </mxCell>
        <mxCell id="php-runtime" value="&lt;b&gt;Apache + PHP 8.2&lt;/b&gt;&lt;br&gt;XAMPP localhost:8080/midtermgroup&lt;br&gt;部署時可對應 InfinityFree / Apache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#271040;strokeColor=#FF00FF;fontColor=#FFE6FF;arcSize=10;" vertex="1" parent="server-layer">
          <mxGeometry x="25" y="55" width="370" height="95" as="geometry" />
        </mxCell>
        <mxCell id="includes" value="&lt;b&gt;共用後端模組&lt;/b&gt;&lt;br&gt;config.php：Session / DB 連線&lt;br&gt;functions.php：登入檢查、購物車、訂單、付款&lt;br&gt;innovation.php：促銷、點數、合作店、營業時間&lt;br&gt;password-reset.php：忘記密碼 token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#271040;strokeColor=#C084FC;fontColor=#F5E8FF;arcSize=10;" vertex="1" parent="server-layer">
          <mxGeometry x="25" y="175" width="370" height="135" as="geometry" />
        </mxCell>
        <mxCell id="api-endpoints" value="&lt;b&gt;AJAX / API 端點&lt;/b&gt;&lt;br&gt;api.php：評論、客服案件、管理刪除&lt;br&gt;exchange-rate.php：匯率 JSON&lt;br&gt;logout.php：登出 Session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#271040;strokeColor=#FFB3FF;fontColor=#FFE6FF;arcSize=10;" vertex="1" parent="server-layer">
          <mxGeometry x="25" y="335" width="370" height="100" as="geometry" />
        </mxCell>
        <mxCell id="admin-pages" value="&lt;b&gt;後台管理頁&lt;/b&gt;&lt;br&gt;admin/index.php 儀表板&lt;br&gt;products.php 商品 / 庫存&lt;br&gt;orders.php 訂單狀態&lt;br&gt;payments.php 付款紀錄&lt;br&gt;analytics.php 銷售分析&lt;br&gt;marketing.php 活動 / 合作 / 營業時間&lt;br&gt;users.php 會員管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B0A3D;strokeColor=#FF00FF;fontColor=#FFE6FF;arcSize=10;" vertex="1" parent="server-layer">
          <mxGeometry x="25" y="455" width="370" height="150" as="geometry" />
        </mxCell>

        <mxCell id="data-layer" value="資料庫 MySQL 層" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#06251E;strokeColor=#22C55E;fontColor=#FFFFFF;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1450" y="130" width="300" height="520" as="geometry" />
        </mxCell>
        <mxCell id="core-tables" value="&lt;b&gt;核心交易資料表&lt;/b&gt;&lt;br&gt;users&lt;br&gt;noodles&lt;br&gt;orders&lt;br&gt;order_items&lt;br&gt;payments&lt;br&gt;topping_options" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B2E;strokeColor=#22C55E;fontColor=#DCFCE7;arcSize=10;" vertex="1" parent="data-layer">
          <mxGeometry x="25" y="55" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="innovation-tables" value="&lt;b&gt;優化後新增 / 擴充&lt;/b&gt;&lt;br&gt;promotions&lt;br&gt;user_points&lt;br&gt;point_transactions&lt;br&gt;rewards&lt;br&gt;reward_redemptions&lt;br&gt;partners&lt;br&gt;store_hours&lt;br&gt;order_reviews&lt;br&gt;support_cases&lt;br&gt;password_reset_tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B3B2E;strokeColor=#86EFAC;fontColor=#DCFCE7;arcSize=10;" vertex="1" parent="data-layer">
          <mxGeometry x="25" y="225" width="250" height="240" as="geometry" />
        </mxCell>

        <mxCell id="external-layer" value="外部 / 模擬服務" style="swimlane;html=1;startSize=32;rounded=1;fillColor=#2B1E05;strokeColor=#F59E0B;fontColor=#FFFFFF;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="240" y="710" width="1510" height="250" as="geometry" />
        </mxCell>
        <mxCell id="payment-sandbox" value="&lt;b&gt;Sandbox 付款&lt;/b&gt;&lt;br&gt;checkout.php 驗證測試卡號&lt;br&gt;processPayment() 產生 transaction_id&lt;br&gt;不串接真實金流" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B2A08;strokeColor=#F59E0B;fontColor=#FFF7ED;arcSize=10;" vertex="1" parent="external-layer">
          <mxGeometry x="35" y="60" width="310" height="115" as="geometry" />
        </mxCell>
        <mxCell id="exchange-service" value="&lt;b&gt;匯率服務&lt;/b&gt;&lt;br&gt;exchange-rate.php&lt;br&gt;瀏覽器 fallback：Frankfurter API&lt;br&gt;USD / TWD 切換" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B2A08;strokeColor=#FBBF24;fontColor=#FFF7ED;arcSize=10;" vertex="1" parent="external-layer">
          <mxGeometry x="395" y="60" width="310" height="115" as="geometry" />
        </mxCell>
        <mxCell id="maps-service" value="&lt;b&gt;地圖嵌入&lt;/b&gt;&lt;br&gt;locations.php&lt;br&gt;Google Maps iframe&lt;br&gt;據點為模擬資料" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B2A08;strokeColor=#FBBF24;fontColor=#FFF7ED;arcSize=10;" vertex="1" parent="external-layer">
          <mxGeometry x="755" y="60" width="310" height="115" as="geometry" />
        </mxCell>
        <mxCell id="browser-storage" value="&lt;b&gt;瀏覽器本機狀態&lt;/b&gt;&lt;br&gt;localStorage&lt;br&gt;語言、幣別、上方選單收合狀態&lt;br&gt;不影響後端資料" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3B2A08;strokeColor=#FBBF24;fontColor=#FFF7ED;arcSize=10;" vertex="1" parent="external-layer">
          <mxGeometry x="1115" y="60" width="310" height="115" as="geometry" />
        </mxCell>

        <mxCell id="note-optimization" value="&lt;b&gt;本次優化重點&lt;/b&gt;&lt;br&gt;1. 全站共用登入 / 會員 / 登出 / 購物車導覽&lt;br&gt;2. 全站頁尾一致化與品牌故事&lt;br&gt;3. 中英文與 USD/TWD 切換補強&lt;br&gt;4. register.php 密碼強度與眼睛顯示&lt;br&gt;5. 首頁、會員、促銷、點數、據點、設備監控強化營業真實感" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#60A5FA;fontColor=#DBEAFE;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="990" width="1720" height="115" as="geometry" />
        </mxCell>

        <mxCell id="e-guest-public" value="瀏覽 / 註冊 / 登入" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#00FFFF;fontColor=#EAFBFF;" edge="1" parent="1" source="actor-guest" target="public-pages">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-member-order" value="點餐 / 會員功能" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#00FFFF;fontColor=#EAFBFF;" edge="1" parent="1" source="actor-member" target="ordering-pages">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-admin-admin" value="管理後台" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#FF00FF;fontColor=#FFE6FF;" edge="1" parent="1" source="actor-admin" target="admin-pages">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-pages-php" value="HTTP Request / PHP Render" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#60A5FA;fontColor=#DBEAFE;" edge="1" parent="1" source="frontend-layer" target="php-runtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-php-includes" value="require_once / include" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#C084FC;fontColor=#F5E8FF;" edge="1" parent="1" source="php-runtime" target="includes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-server-db" value="mysqli query / transaction" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#22C55E;fontColor=#DCFCE7;" edge="1" parent="1" source="includes" target="core-tables">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-server-db2" value="促銷、點數、營運資料" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#86EFAC;fontColor=#DCFCE7;" edge="1" parent="1" source="includes" target="innovation-tables">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-js-api" value="fetch / AJAX" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#FBBF24;fontColor=#FFF7ED;" edge="1" parent="1" source="frontend-js" target="api-endpoints">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-checkout-payment" value="付款模擬" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#F59E0B;fontColor=#FFF7ED;" edge="1" parent="1" source="ordering-pages" target="payment-sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-exchange" value="匯率資料" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#F59E0B;fontColor=#FFF7ED;" edge="1" parent="1" source="frontend-js" target="exchange-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-maps" value="iframe embed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#F59E0B;fontColor=#FFF7ED;" edge="1" parent="1" source="member-pages" target="maps-service">
